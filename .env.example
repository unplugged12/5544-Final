# LLM Provider Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
PRIMARY_PROVIDER=openai
FALLBACK_PROVIDER=anthropic
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Database
SQLITE_PATH=/app/data/copilot.db
CHROMA_PERSIST_DIR=/app/data/chroma
CHROMA_COLLECTION=knowledge_base
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Discord Bot
DISCORD_TOKEN=your-bot-token
DISCORD_GUILD_ID=123456789012345678
SANDBOX_CHANNEL_ID=123456789012345678

# App Settings
TOP_K_RESULTS=5
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:15173

# Chat Feature

# Master kill switch for @-mention chat. Set to "false" to disable chat on
# next bot restart. For immediate effect without a restart, use the
# /toggle-chat admin slash command (writes the DB flag which takes precedence
# after the ~30s cache window). Default: true.
CHAT_ENABLED=true

CHAT_MODEL_MAX_TOKENS=300
CHAT_INPUT_MAX_CHARS=1500
CHAT_HISTORY_MAX_TURNS=6
CHAT_HISTORY_TTL_MINUTES=15
CHAT_ALLOWED_URL_DOMAINS=discord.com

# Documented budget ceiling — NOT currently enforced at runtime.
# Monitor real usage via GET /api/metrics/chat. Enforcement is a tracked follow-up.
CHAT_DAILY_TOKEN_BUDGET=200000

# Observability (PR 7) — MUST be set in all non-test deployments.
# CHAT_LOG_HMAC_SECRET: Server-side secret used to HMAC-SHA256 Discord user IDs
#   before writing them to structured logs. Keeps logs correlation-capable while
#   preventing raw user IDs from appearing in log sinks. Generate with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
CHAT_LOG_HMAC_SECRET=REPLACE_ME_WITH_SECRET

# CHAT_ADMIN_TOKEN: Bearer token required to call GET /api/metrics/chat.
#   If left as the sentinel default the endpoint returns 503 (misconfiguration guard).
#   Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CHAT_ADMIN_TOKEN=REPLACE_ME_WITH_ADMIN_TOKEN
